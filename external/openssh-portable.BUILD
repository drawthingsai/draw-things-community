package(default_visibility = ["//visibility:public"])

config_setting(
    name = "ios_build",
    constraint_values = [
        "@platforms//os:ios",
    ],
)

COMMON_COPTS = [
    "-DHAVE_CONFIG_H",
    "-DIOS_SYSTEM_OPENSSH=1",
    "-Dxasprintf=openssh_xasprintf",
    "-include",
    "OpenSSHPort.h",
    "-Wno-deprecated-declarations",
    "-Wno-format",
    "-Wno-incompatible-function-pointer-types",
    "-Wno-int-conversion",
    "-Wno-pointer-sign",
    "-Wno-shorten-64-to-32",
    "-Wno-sign-compare",
    "-Wno-unused-function",
    "-Wno-unused-parameter",
    "-Wno-unused-variable",
    "-fcommon",
]

OPENBSD_COMPAT_SRCS = [
    "openbsd-compat/arc4random.c",
    "openbsd-compat/arc4random_uniform.c",
    "openbsd-compat/base64.c",
    "openbsd-compat/basename.c",
    "openbsd-compat/bcrypt_pbkdf.c",
    "openbsd-compat/bindresvport.c",
    "openbsd-compat/blowfish.c",
    "openbsd-compat/bsd-asprintf.c",
    "openbsd-compat/bsd-closefrom.c",
    "openbsd-compat/bsd-cygwin_util.c",
    "openbsd-compat/bsd-err.c",
    "openbsd-compat/bsd-flock.c",
    "openbsd-compat/bsd-getentropy.c",
    "openbsd-compat/bsd-getline.c",
    "openbsd-compat/bsd-getpagesize.c",
    "openbsd-compat/bsd-getpeereid.c",
    "openbsd-compat/bsd-malloc.c",
    "openbsd-compat/bsd-misc.c",
    "openbsd-compat/bsd-nextstep.c",
    "openbsd-compat/bsd-openpty.c",
    "openbsd-compat/bsd-poll.c",
    "openbsd-compat/bsd-pselect.c",
    "openbsd-compat/bsd-setres_id.c",
    "openbsd-compat/bsd-signal.c",
    "openbsd-compat/bsd-snprintf.c",
    "openbsd-compat/bsd-statvfs.c",
    "openbsd-compat/bsd-timegm.c",
    "openbsd-compat/bsd-waitpid.c",
    "openbsd-compat/daemon.c",
    "openbsd-compat/dirname.c",
    "openbsd-compat/explicit_bzero.c",
    "openbsd-compat/fake-rfc2553.c",
    "openbsd-compat/fmt_scaled.c",
    "openbsd-compat/fnmatch.c",
    "openbsd-compat/freezero.c",
    "openbsd-compat/getcwd.c",
    "openbsd-compat/getgrouplist.c",
    "openbsd-compat/getopt_long.c",
    "openbsd-compat/getrrsetbyname-ldns.c",
    "openbsd-compat/getrrsetbyname.c",
    "openbsd-compat/glob.c",
    "openbsd-compat/inet_aton.c",
    "openbsd-compat/inet_ntoa.c",
    "openbsd-compat/inet_ntop.c",
    "openbsd-compat/kludge-fd_set.c",
    "openbsd-compat/libressl-api-compat.c",
    "openbsd-compat/md5.c",
    "openbsd-compat/memmem.c",
    "openbsd-compat/mktemp.c",
    "openbsd-compat/openssl-compat.c",
    "openbsd-compat/port-aix.c",
    "openbsd-compat/port-irix.c",
    "openbsd-compat/port-linux.c",
    "openbsd-compat/port-net.c",
    "openbsd-compat/port-prngd.c",
    "openbsd-compat/port-solaris.c",
    "openbsd-compat/port-uw.c",
    "openbsd-compat/pwcache.c",
    "openbsd-compat/readpassphrase.c",
    "openbsd-compat/reallocarray.c",
    "openbsd-compat/recallocarray.c",
    "openbsd-compat/rresvport.c",
    "openbsd-compat/setenv.c",
    "openbsd-compat/setproctitle.c",
    "openbsd-compat/sha1.c",
    "openbsd-compat/sha2.c",
    "openbsd-compat/sigact.c",
    "openbsd-compat/strcasestr.c",
    "openbsd-compat/strlcat.c",
    "openbsd-compat/strlcpy.c",
    "openbsd-compat/strmode.c",
    "openbsd-compat/strndup.c",
    "openbsd-compat/strnlen.c",
    "openbsd-compat/strptime.c",
    "openbsd-compat/strsep.c",
    "openbsd-compat/strtoll.c",
    "openbsd-compat/strtonum.c",
    "openbsd-compat/strtoul.c",
    "openbsd-compat/strtoull.c",
    "openbsd-compat/timingsafe_bcmp.c",
    "openbsd-compat/vis.c",
    "openbsd-compat/xcrypt.c",
]

LIBSSH_SRCS = [
    "addr.c",
    "addrmatch.c",
    "atomicio.c",
    "authfd.c",
    "authfile.c",
    "bitmap.c",
    "canohost.c",
    "chacha.c",
    "channels.c",
    "cipher-aes.c",
    "cipher-aesctr.c",
    "cipher-chachapoly-libcrypto.c",
    "cipher-chachapoly.c",
    "cipher.c",
    "cleanup.c",
    "compat.c",
    "dh.c",
    "digest-libc.c",
    "digest-openssl.c",
    "dispatch.c",
    "dns.c",
    "ed25519-openssl.c",
    "ed25519.c",
    "entropy.c",
    "fatal.c",
    "gss-genr.c",
    "hmac.c",
    "hostfile.c",
    "kex-names.c",
    "kex.c",
    "kexc25519.c",
    "kexecdh.c",
    "kexdh.c",
    "kexgen.c",
    "kexgex.c",
    "kexgexc.c",
    "kexgexs.c",
    "kexmlkem768x25519.c",
    "kexsntrup761x25519.c",
    "krl.c",
    "libcrux-mlkem-mldsa.c",
    "log.c",
    "mac.c",
    "match.c",
    "misc-agent.c",
    "misc.c",
    "moduli.c",
    "monitor_fdpass.c",
    "msg.c",
    "nchan.c",
    "packet.c",
    "platform-misc.c",
    "platform-pledge.c",
    "platform-tracing.c",
    "poly1305.c",
    "readpass.c",
    "rijndael.c",
    "sftp-realpath.c",
    "sntrup761.c",
    "ssh-ecdsa-sk.c",
    "ssh-ecdsa.c",
    "ssh-ed25519-sk.c",
    "ssh-ed25519.c",
    "ssh-mldsa-eddsa.c",
    "ssh-rsa.c",
    "ssh_api.c",
    "sshbuf-getput-basic.c",
    "sshbuf-getput-crypto.c",
    "sshbuf-io.c",
    "sshbuf-misc.c",
    "sshbuf.c",
    "ssherr-libcrypto.c",
    "ssherr.c",
    "sshkey.c",
    "ttymodes.c",
    "umac.c",
    "umac128.c",
    "utf8.c",
    "xmalloc.c",
]

objc_library(
    name = "curve25519",
    srcs = ["smult_curve25519_ref.c"],
    copts = [
        "-Wno-sign-compare",
        "-fcommon",
    ],
)

objc_library(
    name = "openbsd_compat",
    srcs = OPENBSD_COMPAT_SRCS,
    hdrs = glob([
        "*.h",
        "openbsd-compat/*.h",
    ]),
    copts = COMMON_COPTS,
    includes = ["."],
    deps = [
        "@//Vendors/OpenSSH:boringssl_headers",
        "@//Vendors/OpenSSH:compat_headers",
        "@//Vendors/OpenSSH:config",
        "@//Vendors/ios_system:api",
    ],
)

objc_library(
    name = "libssh",
    srcs = LIBSSH_SRCS,
    hdrs = glob(["*.h"]) + ["umac.c"],
    copts = COMMON_COPTS,
    includes = ["."],
    linkopts = [
        "-lc++",
        "-lresolv",
    ],
    deps = [
        ":curve25519",
        ":openbsd_compat",
        "@//Vendors/OpenSSH:boringssl_headers",
        "@//Vendors/OpenSSH:compat_headers",
        "@//Vendors/OpenSSH:config",
        "@//Vendors/ios_system:api",
    ],
)

objc_library(
    name = "ssh",
    srcs = [
        "clientloop.c",
        "mux.c",
        "readconf.c",
        "ssh.c",
        "ssh-pkcs11.c",
        "ssh-sk-client.c",
        "sshconnect.c",
        "sshconnect2.c",
        "sshtty.c",
    ],
    copts = COMMON_COPTS + ["-Dmain=ssh_main"],
    deps = [
        ":libssh",
        "@//Vendors/OpenSSH:config",
        "@//Vendors/ios_system:api",
    ],
)

SFTP_CLIENT_SRCS = [
    "sftp-client.c",
    "sftp-common.c",
    "sftp-glob.c",
]

objc_library(
    name = "scp",
    srcs = [
        "progressmeter.c",
        "scp.c",
    ] + SFTP_CLIENT_SRCS,
    copts = COMMON_COPTS + [
        "-Dcleanup_exit=scp_cleanup_exit",
        "-Dinterrupted=scp_interrupted",
        "-Dmain=scp_main",
        "-Dshowprogress=scp_showprogress",
    ],
    deps = [
        ":libssh",
        "@//Vendors/OpenSSH:config",
        "@//Vendors/ios_system:api",
    ],
)

objc_library(
    name = "sftp",
    srcs = [
        "progressmeter.c",
        "sftp.c",
        "sftp-usergroup.c",
    ] + SFTP_CLIENT_SRCS,
    copts = COMMON_COPTS + [
        "-Dinterrupted=sftp_interrupted",
        "-Dmain=sftp_main",
        "-Dshowprogress=sftp_showprogress",
    ],
    deps = [
        ":libssh",
        "@//Vendors/OpenSSH:config",
        "@//Vendors/ios_system:api",
    ],
)

objc_library(
    name = "commands",
    deps = [
        ":scp",
        ":sftp",
        ":ssh",
    ],
)
